<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/night_shield_widget_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="4dp">

    <ImageView
        android:id="@+id/shieldAction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="@string/widget_description"
        android:src="@drawable/shield_inactive" />

    <!-- STANDARD + DETAILED: ON / OFF label -->
    <TextView
        android:id="@+id/widgetStatusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- DETAILED only: intensity percentage -->
    <TextView
        android:id="@+id/widgetIntensityText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#CCFFFFFF"
        android:textSize="9sp"
        android:visibility="gone" />

</LinearLayout>
